rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Catch-all Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Incident Security ---
    function isValidIncident(data) {
      return data.type is string && data.type.size() <= 50
        && data.severity is int && data.severity >= 1 && data.severity <= 10
        && data.location is string && data.location.size() <= 200
        && data.status in ['active', 'pending', 'resolved', 'dispatched']
        && data.createdAt == request.time;
    }

    match /incidents/{incidentId} {
      // Create: Anyone (Guests for SOS) - PUBLIC INGRESS
      // We allow unauthenticated creation but STRICTLY validate the schema
      allow create: if isValidId(incidentId) 
        && isValidIncident(incoming());

      // Read: Any authenticated user (Staff/Responders)
      allow get, list: if isSignedIn();

      // Update: Restricted fields or Staff only
      allow update: if isSignedIn()
        && (
          // Action: Resolve Incident (Staff only ideally, but simplifying for prototype)
          (existing().status != 'resolved' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'aiSummary']))
          || (isOwner(existing().reportedBy) && incoming().diff(existing()).affectedKeys().hasOnly(['location', 'updatedAt']))
        );
      
      // --- Message Security ---
      match /messages/{messageId} {
        function isValidMessage(data) {
          return data.text is string && data.text.size() <= 1000
            && data.senderType in ['guest', 'staff', 'responder', 'system']
            && data.timestamp == request.time;
        }

        // Allow everyone to create messages for public SOS coordination
        allow create: if isValidId(messageId)
          && isValidMessage(incoming());

        allow list, get: if isSignedIn();
      }
    }

    // --- Staff Security ---
    match /staff/{staffId} {
      allow read: if isSignedIn();
      allow write: if isOwner(staffId);
    }
  }
}
